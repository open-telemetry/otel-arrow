{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "constraints": {
    // primary usage of Golang components is in
    // OpenTelemetry-Collector-Contrib repository which
    // currently enforces 1.25.0 compatibility
    "go": "1.25.0",
    // keep pip-compile refreshes aligned with CI/runtime interpreter
    "python": "==3.11"
  },
  "extends": [
    "config:recommended",
    "docker:pinDigests",
    "helpers:pinGitHubActionDigestsToSemver"
  ],
  "ignorePaths": [
    // this directory has generated code, don't send updates to it
    "collector/cmd/otelarrowcol/**",
    // this reference implementation has been removed from our build pipelines
    "rust/beaubourg/**"
  ],
  // NOTE: Rule ordering matters here
  // Later rules will override earlier rules
  "packageRules": [
    {
      // reduces the number of Renovate PRs
      // (patch updates are typically non-breaking)
      "groupName": "all patch versions",
      "matchUpdateTypes": [
        "patch"
      ],
      "schedule": [
        "before 8am every weekday"
      ]
    },
    {
      // avoids these Renovate PRs from trickling in throughout the week
      // (consolidating the review process)
      "matchUpdateTypes": [
        "minor",
        "major"
      ],
      "schedule": [
        "before 8am on Monday"
      ]
    },
    {
      // group together all github action workflow changes
      // it is very rare to have issues with these upgrades
      // fine to take them together
      "groupName": "github workflow dependencies",
      "matchFileNames": [".github/workflows/*.yml", ".github/workflows/*.yaml"],
      "schedule": [
        "before 8am on the first day of the month"
      ]
    },
    {
      // update docker digest hashes only once a month
      // reduces frequency of digest-only updates
      "groupName": "docker digest updates",
      "matchUpdateTypes": ["digest"],
      "matchFileNames": ["**/Dockerfile"],
      "schedule": [
        "before 8am on the first day of the month"
      ]
    },
    {
      // keep pip-compile source + lock updates together in one PR stream
      "groupName": "pipeline perf python dependencies",
      "matchManagers": ["pip-compile"],
      "matchFileNames": [
        "tools/pipeline_perf_test/**/requirements.lock.txt",
        "tools/pipeline_perf_test/**/requirements.txt"
      ]
    },
    {
      // prevent duplicate PRs from pip_requirements once pip-compile is enabled
      "matchManagers": ["pip_requirements"],
      "matchFileNames": ["tools/pipeline_perf_test/**/requirements.txt"],
      "enabled": false
    },
  ],
  // activate pip-compile manager on generated output lock files
  "pip-compile": {
    "managerFilePatterns": [
      "/(^|/)tools\\/pipeline_perf_test\\/.+\\/requirements\\.lock\\.txt$/"
    ]
  },
  "lockFileMaintenance": {
    "enabled": true,
    "branchTopic": "pip-compile-refresh",
    "commitMessageAction": "Refresh pip-compile outputs"
  },
  "postUpdateOptions": [
    // see https://docs.renovatebot.com/golang/#module-tidying
    // go modules may require running go mod tidy to pass CI
    "gomodTidy"
  ],
  "labels": [
    "dependencies"
  ]
}