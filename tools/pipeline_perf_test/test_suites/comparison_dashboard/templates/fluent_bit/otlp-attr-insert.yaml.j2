service:
  flush: 1
  log_level: info
  http_server: on
  http_listen: 0.0.0.0
  http_port: 2020

pipeline:
  inputs:
    - name: opentelemetry
      listen: 0.0.0.0
      port: 4317
      http2: on
      threaded: off
      processors:
        logs:
{%- for a in insert_actions %}
          - name: content_modifier
            context: otel_log_attributes
            action: insert
            key: {{ a.key }}
            value: {{ a.value }}
{%- endfor %}

  outputs:
    - name: opentelemetry
      match: '*'
      host: {{ backend_hostname }}
      port: 1235
      grpc: on
      tls: off
      workers: 0
      retry_limit: false
{%- if compression_method and compression_method != "none" %}
      compress: {{ compression_method }}
{%- endif %}
