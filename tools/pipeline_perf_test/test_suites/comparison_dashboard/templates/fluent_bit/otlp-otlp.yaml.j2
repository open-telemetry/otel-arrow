# Fluent Bit OTLP/gRPC -> OTLP/gRPC passthrough.
# The opentelemetry input accepts gRPC on the listen port when http2 is on; the
# load generator's otlp_grpc exporter targets port 4317.
# Single-threaded (threaded off, no extra workers) to bind the engine to ~1 core.
service:
  flush: 1
  log_level: info
  http_server: on
  http_listen: 0.0.0.0
  http_port: 2020

pipeline:
  inputs:
    - name: opentelemetry
      listen: 0.0.0.0
      port: 4317
      http2: on
      threaded: off

  outputs:
    - name: opentelemetry
      match: '*'
      host: {{ backend_hostname }}
      port: 1235
      grpc: on
      tls: off
      workers: 0
      retry_limit: false
{%- if compression_method and compression_method != "none" %}
      compress: {{ compression_method }}
{%- endif %}
