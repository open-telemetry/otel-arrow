receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317

processors:
  attributes:
    actions:
{%- set rename_pairs = [
    ["exception.type", "exception.kind"],
    ["http.request.method", "http.method"],
    ["http.route", "http.path_template"],
    ["user.id", "end_user.id"],
] %}
{%- set n = transform_count | default(1) | int %}
{%- for pair in rename_pairs[:n] %}
      - key: {{pair[1]}}
        from_attribute: {{pair[0]}}
        action: insert
      - key: {{pair[0]}}
        action: delete
{%- endfor %}

exporters:
  otlp:
    endpoint: '{{backend_hostname}}:1235'
    compression: {{ compression_method | default("none") }}
    tls:
      insecure: true
    sending_queue:
      enabled: {{ sending_queue_enabled | default(true) }}
      wait_for_result: {{ wait_for_result | default(true) }}
      block_on_overflow: {{ block_on_overflow | default(true) }}
      sizer: {{ sending_queue_sizer | default("requests") }}
      queue_size: {{ sending_queue_size | default(100) }}

service:
  telemetry:
    metrics:
      readers:
        - pull:
            exporter:
              prometheus:
                host: '0.0.0.0'
                port: 8086
  pipelines:
    logs:
      receivers: [otlp]
      processors: [attributes]
      exporters: [otlp]
    metrics:
      receivers: [otlp]
      exporters: [otlp]
    traces:
      receivers: [otlp]
      exporters: [otlp]
