receivers:
  otlp:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317

processors:
  attributes:
    actions:
{# Source keys must match attributes that the loadgen actually emits.
Suites that need all N renames to fire on every record should use
data_source=synthetic with num_log_attributes >= 12 (then ATTR_NAMES
indices 8..11 below are guaranteed on every log record). Suites using
data_source=semantic_conventions will only see the first pair fire on
records from Event groups that include exception.type (e.g. event.exception,
http.client.request.exception). #}
{%- set rename_pairs = [
    ["exception.type", "exception.kind"],
    ["exception.message", "exception.msg"],
    ["exception.stacktrace", "exception.trace"],
    ["user.id", "end_user.id"],
] %}
{%- set n = transform_count | default(1) | int %}
{%- for pair in rename_pairs[:n] %}
      - key: {{pair[1]}}
        from_attribute: {{pair[0]}}
        action: insert
      - key: {{pair[0]}}
        action: delete
{%- endfor %}

exporters:
  otlp:
    endpoint: '{{backend_hostname}}:1235'
    compression: {{ compression_method | default("none") }}
    tls:
      insecure: true
    sending_queue:
      enabled: {{ sending_queue_enabled | default(true) }}
      wait_for_result: {{ wait_for_result | default(true) }}
      block_on_overflow: {{ block_on_overflow | default(true) }}
      sizer: {{ sending_queue_sizer | default("requests") }}
      queue_size: {{ sending_queue_size | default(100) }}

service:
  telemetry:
    metrics:
      readers:
        - pull:
            exporter:
              prometheus:
                host: '0.0.0.0'
                port: 8086
  pipelines:
    logs:
      receivers: [otlp]
      processors: [attributes]
      exporters: [otlp]
    metrics:
      receivers: [otlp]
      exporters: [otlp]
    traces:
      receivers: [otlp]
      exporters: [otlp]
