receivers:
  otelarrow:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317

processors:
  attributes:
    actions:
{%- for p in rename_pairs %}
      - key: {{ p.destination }}
        from_attribute: {{ p.source }}
        action: insert
      - key: {{ p.source }}
        action: delete
{%- endfor %}

exporters:
  otelarrow:
    endpoint: '{{backend_hostname}}:1235'
    compression: {{ compression_method | default("none") }}
    tls:
      insecure: true
    arrow:
      payload_compression: {{ payload_compression | default("none") }}
      disabled: false
    sending_queue:
      enabled: {{ sending_queue_enabled | default(true) }}
      wait_for_result: {{ wait_for_result | default(true) }}
      block_on_overflow: {{ block_on_overflow | default(true) }}
      sizer: {{ sending_queue_sizer | default("requests") }}
      queue_size: {{ sending_queue_size | default(100) }}

service:
  telemetry:
    metrics:
      readers:
        - pull:
            exporter:
              prometheus:
                host: '0.0.0.0'
                port: 8086
  pipelines:
    logs/arrow:
      receivers: [otelarrow]
      processors: [attributes]
      exporters: [otelarrow]
    metrics/arrow:
      receivers: [otelarrow]
      exporters: [otelarrow]
    traces/arrow:
      receivers: [otelarrow]
      exporters: [otelarrow]
