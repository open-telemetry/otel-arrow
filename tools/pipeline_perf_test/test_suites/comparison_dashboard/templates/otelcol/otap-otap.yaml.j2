receivers:
  otelarrow:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317
    admission:
      request_limit_mib: {{ admission_request_mib | default(128) }}
      waiting_limit_mib: {{ admission_waiting_mib | default(32) }}

exporters:
  otelarrow:
    endpoint: '{{backend_hostname}}:1235'
    compression: {{ compression_method | default("none") }}
    tls:
      insecure: true
    arrow:
      payload_compression: {{ payload_compression | default("none") }}
      disabled: false
      num_streams: {{ num_streams | default(5) }}
    sending_queue:
      enabled: {{ sending_queue_enabled | default(true) }}
      wait_for_result: {{ wait_for_result | default(true) }}
      block_on_overflow: {{ block_on_overflow | default(true) }}
      sizer: {{ sending_queue_sizer | default("requests") }}
      queue_size: {{ sending_queue_size | default(100) }}
      num_consumers: {{ sending_queue_otap_consumers | default(100) }}
      batch:
        enabled: {{ sending_queue_batch_enabled | default(false) }}
        # batch.sizer set to work around upstream nil-deref when sending_queue.sizer is set and batch.enabled=false.
        sizer: {{ sending_queue_sizer | default("requests") }}

service:
  telemetry:
    metrics:
      readers:
        - pull:
            exporter:
              prometheus:
                host: '0.0.0.0'
                port: 8086
  pipelines:
    logs/arrow:
      receivers: [otelarrow]
      exporters: [otelarrow]
    metrics/arrow:
      receivers: [otelarrow]
      exporters: [otelarrow]
    traces/arrow:
      receivers: [otelarrow]
      exporters: [otelarrow]
