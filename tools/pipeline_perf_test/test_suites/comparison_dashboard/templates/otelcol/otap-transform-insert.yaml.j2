receivers:
  otelarrow:
    protocols:
      grpc:
        endpoint: 0.0.0.0:4317

processors:
  transform:
    error_mode: ignore
    log_statements:
      - context: log
        statements:
{%- for a in insert_actions %}
          - set(attributes["{{ a.key }}"], "{{ a.value }}")
{%- endfor %}

exporters:
  otelarrow:
    endpoint: '{{backend_hostname}}:1235'
    compression: {{ compression_method | default("none") }}
    tls:
      insecure: true
    arrow:
      payload_compression: {{ payload_compression | default("none") }}
      disabled: false
    sending_queue:
      enabled: {{ sending_queue_enabled | default(true) }}
      wait_for_result: {{ wait_for_result | default(true) }}
      block_on_overflow: {{ block_on_overflow | default(true) }}
      sizer: {{ sending_queue_sizer | default("requests") }}
      queue_size: {{ sending_queue_size | default(100) }}

service:
  telemetry:
    metrics:
      readers:
        - pull:
            exporter:
              prometheus:
                host: '0.0.0.0'
                port: 8086
  pipelines:
    logs/arrow:
      receivers: [otelarrow]
      processors: [transform]
      exporters: [otelarrow]
    metrics/arrow:
      receivers: [otelarrow]
      exporters: [otelarrow]
    traces/arrow:
      receivers: [otelarrow]
      exporters: [otelarrow]
