{%- set transport = syslog_transport | default("udp") -%}
{%- set exporter_type = exporter | default("otap") -%}
version: otel_dataflow/v1
policies:
  channel_capacity:
    control:
      node: 100
      pipeline: 100
    pdata: 100
engine:
  telemetry:
    logs:
      level: info
groups:
  default:
    pipelines:
      main:
        nodes:
          receiver:
            type: urn:otel:receiver:syslog_cef
            config:
              protocol:
                {{ transport }}:
                  listening_addr: "0.0.0.0:4317"
          attr:
            type: urn:otel:processor:attribute
            config:
              actions:
              - action: rename
                source_key: name
                destination_key: name2
                apply_to:
                - scope
          exporter:
            {%- if exporter_type == "otap" %}
            type: urn:otel:exporter:otap
            config:
              grpc_endpoint: http://{{backend_hostname}}:1235
              compression_method: zstd
              arrow:
                payload_compression: none
            {%- else %}
            type: urn:otel:exporter:otlp_grpc
            config:
              grpc_endpoint: http://{{backend_hostname}}:1235
              compression_method: gzip
            {%- endif %}
        connections:
        - from: receiver
          to: attr
        - from: attr
          to: exporter
