---
source: example-data-plane/crates/exporters/src/clickhouse_exporter/tables.rs
expression: view_sql
---

CREATE VIEW IF NOT EXISTS otap.otel_traces AS
SELECT
    signal.Timestamp as Timestamp,
    signal.TraceId,
    signal.SpanId,
    signal.ParentSpanId,
    signal.TraceState,
    signal.SpanName,
    signal.SpanKind,
    signal.ServiceName,
    ra.attributes as ResourceAttributes,
    signal.ScopeName,
    signal.ScopeVersion,
    sa.attributes as ScopeAttributes,
    ta.attributes as SpanAttributes,
    signal.Duration,
    signal.StatusCode,
    signal.StatusMessage,
    signal.`Events.Timestamp`,
    signal.`Events.Name`,
    signal.`Events.Attributes`,
    signal.`Links.TraceId`,
    signal.`Links.SpanId`,
    signal.`Links.TraceState`,
    signal.`Links.Attributes`
FROM otap.otel_traces_raw AS signal

LEFT JOIN otap.otel_resource_attributes AS ra
    ON signal.part_id     = ra.part_id
    AND signal.resource_id = ra.parent_id


LEFT JOIN otap.otel_scope_attributes AS sa
    ON signal.part_id     = sa.part_id
    AND signal.scope_id = sa.parent_id


LEFT JOIN otap.otel_trace_attributes AS ta
    ON signal.part_id     = ta.part_id
    AND signal.id = ta.parent_id
